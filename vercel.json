{
  "version": 2,
  "functions": {
    "app.py": {
      "includeFiles": [
        "frontend/public/**",
        "frontend/src/**",
        "examples/**",
        "src/ets/**"
      ]
    }
  },
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ]
}
